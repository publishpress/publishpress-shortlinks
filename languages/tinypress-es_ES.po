msgid "Prevent Auto Links Inside Classes or IDs"
msgstr "Impedir enlaces automáticos dentro de clases o ID"

#: includes-core/ShortlinksCoreAdmin.php:386
msgid ""
"Content inside elements with these classes or IDs will not have autolinks "
"applied."
msgstr ""
"No se aplicarán enlaces automáticos al contenido que se encuentre dentro de "
"los elementos con estas clases o ID."

