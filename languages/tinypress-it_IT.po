msgid "Prevent Auto Links Inside Classes or IDs"
msgstr "Impedisci i link automatici all'interno di classi o ID"

#: includes-core/ShortlinksCoreAdmin.php:386
msgid ""
"Content inside elements with these classes or IDs will not have autolinks "
"applied."
msgstr ""
"I link automatici non saranno applicati al contenuto dentro gli elementi con "
"queste classi o questi ID."

#: includes-core/ShortlinksCoreAdmin.php:388
msgid "Prevent Auto Links Inside Elements"
msgstr "Impedisci i link automatici all'interno degli elementi"

#: includes-core/ShortlinksCoreAdmin.php:389
msgid "Terms inside these HTML tags will not have autolinks applied."
msgstr ""
"I collegamenti automatici non verranno applicati ai termini all'interno di "
"questi tag HTML."

#: includes-core/ShortlinksCoreAdmin.php:402
msgid "Prevent Auto Links on Shortcodes"
msgstr "Impedisci i link automatici negli shortcode"

#: includes-core/ShortlinksCoreAdmin.php:403
msgid "Terms inside these shortcodes will not have autolinks applied."
msgstr ""
"I collegamenti automatici non verranno applicati ai termini all'interno di "
"questi shortcode."

#: includes-core/ShortlinksCoreAdmin.php:405
msgid "Prevent Auto Links on Blocks"
msgstr "Impedisci i link automatici nei blocchi"

#: includes-core/ShortlinksCoreAdmin.php:406
msgid "Terms inside these Gutenberg blocks will not have autolinks applied."
msgstr ""
"I collegamenti automatici non verranno applicati ai termini all'interno di "
"questi blocchi di Gutenberg."

