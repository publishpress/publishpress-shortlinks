msgstr "Totale massimo di link automatici consentiti per articolo/pagina."

#: includes-core/ShortlinksCoreAdmin.php:355
msgid "Minimum Character Length"
msgstr "Lunghezza minima dei caratteri"

#: includes-core/ShortlinksCoreAdmin.php:356
msgid "Keywords shorter than this will not be autolinked."
msgstr ""
"Le parole chiave più corte di questa non saranno collegate automaticamente."

