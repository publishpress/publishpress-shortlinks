msgid "Minimum Keyword Usage"
msgstr "Utilizzo minimo della parola chiave"

#: includes-core/ShortlinksCoreAdmin.php:319
msgid "Keyword must appear this many times before being autolinked."
msgstr ""
"La parola chiave deve apparire questo numero di volte prima che sia "
"collegata automaticamente."

