# Docker container name
CONTAINER_NAME="publishpress-shortlinks"

# Docker image name
TERMINAL_IMAGE_NAME="publishpress/dev-workspace-terminal:publishpress-shortlinks"

# Path to the cache directory for the dev-workspace
CACHE_PATH="./.cache"

# The slug of the plugin to be tested.
PLUGIN_SLUG="publishpress-shortlinks"

# The domain of the plugin to be tested.
LANG_DOMAIN="publishpress-shortlinks"

# The directory of the language files.
LANG_DIR="languages"

# The language locales.
LANG_LOCALES="de_DE es_ES fi fil fr_FR id_ID it_IT ja ko_KR nl_NL pt_BR ru_RU yo"

# OpenAI API key
OPENAI_API_KEY=sk-proj-your-openai-key

# WebLate API token
WEBLATE_API_TOKEN=wlu_your-weblate-token
